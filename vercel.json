{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "crons": [
    {
      "path": "/api/expire-events",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/tiktok-fetch",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/process-videos",
      "schedule": "*/30 6-8 * * *"
    }
  ]
}